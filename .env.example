# ════════════════════════════════════════
# LINE（必須）
# ════════════════════════════════════════
# LINE Developers Console → Basic settings → Channel secret
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Developers Console → Messaging API → Channel access token → "Issue"
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ════════════════════════════════════════
# Anthropic（必須）
# ════════════════════════════════════════
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ════════════════════════════════════════
# Notion（任意 - タスク管理を使う場合）
# ════════════════════════════════════════
# Notion → 設定 → インテグレーション → 新しいインテグレーションを作成
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# NotionのタスクDB ID（デフォルト: CLAUDE.mdに記載のDB）
# NOTION_DB_ID=62a5c6769522437ebd9926a65eacb7b3

# DBのプロパティ名（デフォルト値から変更する場合のみ設定）
# NOTION_PROP_TITLE=名前
# NOTION_PROP_STATUS=ステータス
# NOTION_PROP_PROJECT=プロジェクト
# NOTION_PROP_CATEGORY=カテゴリ
# NOTION_PROP_DUE_DATE=期限

# ════════════════════════════════════════
# Google Calendar（任意 - 予定管理を使う場合）
# ════════════════════════════════════════
# 設定手順:
# 1. Google Cloud Console でプロジェクト作成
#    https://console.cloud.google.com/
# 2. Google Calendar API を有効化
# 3. IAM → サービスアカウント → キー作成（JSON形式）
# 4. DLしたJSONファイルの内容をここに1行で貼り付け
# 5. Google Calendarの「設定と共有」→「特定のユーザーとの共有」に
#    サービスアカウントのメールアドレス（...@...iam.gserviceaccount.com）を追加

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# カレンダーID（デフォルト: primary = Googleアカウントのメインカレンダー）
# GOOGLE_CALENDAR_ID=primary
